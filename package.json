{
  "name": "geo-doctor",
  "version": "0.1.0",
  "description": "Can AI see you? Open-source GEO agent — audit how visible your site is to AI search engines (ChatGPT, Perplexity, Gemini, DeepSeek), with evidence-backed rules and actionable fixes. GEO = Generative Engine Optimization, not geospatial.",
  "keywords": [
    "geo",
    "generative-engine-optimization",
    "aeo",
    "answer-engine-optimization",
    "ai-search",
    "seo",
    "llms-txt",
    "ai-visibility",
    "citation",
    "audit",
    "agent"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/LJMStark/geo-doctor.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "geo-doctor": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs/methodology.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@vitest/coverage-v8": "^3.0.5",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
